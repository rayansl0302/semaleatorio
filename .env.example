# Firebase (Console → Configuração do app Web) — não commite o .env real

# Opcional: domínio .gg — LP em / e app em / (sem barra no final)
# VITE_PUBLIC_SITE_URL=https://semaleatorio.gg

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_MEASUREMENT_ID=

# URL base onde o browser chama POST /api/* (Vercel: o teu domínio de deploy).
# Sem barra no fim. Ex.: https://semaleatorio.vercel.app
VITE_API_URL=
# Alias opcional (mesmo valor que VITE_API_URL)
# VITE_BACKEND_URL=
# Legado: outro host só com rotas /api
# VITE_VERCEL_API_URL=

# Cloud Messaging (Web Push)
# VITE_FCM_VAPID_KEY=

# --- Segredos da API (Riot, Firebase Admin, Asaas): só na Vercel, não aqui ---
# Vê vercel-env.example e cola no dashboard da Vercel.
