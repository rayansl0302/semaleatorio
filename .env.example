# Firebase (Console → Configuração do app Web) — não commite o .env real

# Opcional: domínio .gg — LP em / e app em / (sem barra no final)
# VITE_PUBLIC_SITE_URL=https://semaleatorio.gg
#
# URLs públicas legais (Google OAuth, Firebase, lojas, etc.) após definir VITE_PUBLIC_SITE_URL:
# Política de Privacidade → {VITE_PUBLIC_SITE_URL}/privacidade
# Termos de Serviço       → {VITE_PUBLIC_SITE_URL}/termos

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Feed, mural, perfis e mensagens: Firestore (mesmo projectId acima). Regras e índices no repo.
VITE_FIREBASE_MEASUREMENT_ID=

# Cloud Messaging (Web Push)
# VITE_FCM_VAPID_KEY=

# --- Riot: OAuth recomendado via backend à parte (não incluído neste front-only checkout) ---
# VITE_RIOT_RSO_CLIENT_ID=
# VITE_RIOT_RSO_CLIENT_SECRET=
# VITE_RIOT_RSO_REDIRECT_URI=http://127.0.0.1:5173/app/perfil
#
# Dev só com Vite — proxy CORS (vite.config):
# VITE_RIOT_RSO_TOKEN_URL=/__riot-oauth/token
# VITE_RIOT_RSO_ACCOUNT_ME_URL=/__riot-oauth/account-me

# --- Pagamentos (links Asaas) ---
# URLs em src/lib/asaasPaymentLinks.ts. Retorno opcional: ?pagamento=sucesso no perfil (callback no link).
# VITE_ASAAS_MODE — em localhost a UI assume sandbox; fora disso: sandbox | production (opcional).
