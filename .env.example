# Firebase (Console → Configuração do app Web) — não commite o .env real

# Opcional: domínio .gg — LP em / e app em / (sem barra no final)
# VITE_PUBLIC_SITE_URL=https://semaleatorio.gg
#
# URLs públicas legais (Google OAuth, Firebase, lojas, etc.) após definir VITE_PUBLIC_SITE_URL:
# Política de Privacidade → {VITE_PUBLIC_SITE_URL}/privacidade
# Termos de Serviço       → {VITE_PUBLIC_SITE_URL}/termos

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_MEASUREMENT_ID=

# Opcional: URL base onde o browser chama POST /api/*.
# Na Vercel com `api/` no mesmo projeto podes deixar vazio — usa `/api` na mesma origem.
# Outro host (ex. só API): https://semaleatorio.vercel.app (sem barra no fim).
# Dev: deixa vazio e corre `vercel dev` (porta 3000) + `npm run dev` — o Vite faz proxy de /api.
VITE_API_URL=
# Se `vercel dev` não estiver na 3000: VITE_DEV_API_PROXY=http://127.0.0.1:PORTO
# Alias opcional (mesmo valor que VITE_API_URL)
# VITE_BACKEND_URL=
# Legado: outro host só com rotas /api
# VITE_VERCEL_API_URL=

# Cloud Messaging (Web Push)
# VITE_FCM_VAPID_KEY=

# --- Segredos da API (Riot, Firebase Admin, Asaas): só na Vercel ou em .env local com vercel dev ---
# Vê vercel-env.example (inclui RIOT_RSO_* para login oficial no perfil).
# --- RSO no browser (segredos no bundle; só para iterar) ---
# VITE_RIOT_RSO_CLIENT_ID=
# VITE_RIOT_RSO_CLIENT_SECRET=
# VITE_RIOT_RSO_REDIRECT_URI=http://127.0.0.1:5173/app/perfil
#
# Dev só com Vite — proxy CORS (vite.config):
# VITE_RIOT_RSO_TOKEN_URL=/__riot-oauth/token
# VITE_RIOT_RSO_ACCOUNT_ME_URL=/__riot-oauth/account-me
#
# Vercel — mesma origem, rota sem Firebase:
# VITE_RIOT_RSO_TOKEN_URL=/api/riotRsoBrowserProxy
# VITE_RIOT_RSO_ACCOUNT_ME_URL=/api/riotRsoBrowserProxy
