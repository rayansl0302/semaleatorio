# Front (Vite) — não commites o .env real

# Firebase (Console → Configuração Web)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Realtime Database (feed/mural), se usares
# VITE_FIREBASE_DATABASE_URL=

# Opcional: domínio em produção (legal, SEO)
# VITE_PUBLIC_SITE_URL=https://semaleatorio.gg

# Cloud Functions (se usares)
# VITE_FIREBASE_FUNCTIONS_REGION=us-central1

# Web Push
# VITE_FCM_VAPID_KEY=

