# Firebase (Console → Configuração do app Web) — não commite o .env real

# Opcional: domínio .gg — LP em / e app em / (sem barra no final)
# VITE_PUBLIC_SITE_URL=https://semaleatorio.gg

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_MEASUREMENT_ID=

# API serverless na Vercel (URL do deploy, sem barra no final).
# Em dev local, pode ser o mesmo URL de produção/preview para testar.
VITE_VERCEL_API_URL=https://seu-projeto.vercel.app

# Cloud Messaging (Web Push)
# VITE_FCM_VAPID_KEY=

# --- Variáveis só na Vercel (Settings → Environment Variables), não no bundle: ---
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}  (JSON inteiro numa linha)
# RIOT_API_KEY=
# RIOT_PLATFORM_ROUTING=br1
# RIOT_OAUTH_CLIENT_ID=
# RIOT_OAUTH_CLIENT_SECRET=
# RIOT_OAUTH_REDIRECT_URI=https://seu-projeto.vercel.app/app/riot-callback
# ASAAS_API_KEY=
# ASAAS_API_BASE=https://api-sandbox.asaas.com/v3
# ASAAS_WEBHOOK_TOKEN=  (header asaas-access-token no webhook)
#
# Webhook Asaas: URL pública https://seu-projeto.vercel.app/api/asaasWebhook
