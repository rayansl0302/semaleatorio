# Firebase (Console → Configuração do app Web) — não commite o .env real

# Opcional: domínio .gg — LP em / e app em / (sem barra no final)
# VITE_PUBLIC_SITE_URL=https://semaleatorio.gg

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_MEASUREMENT_ID=

# --- URL do teu backend (Node) — o único servidor que o front chama para Riot/Asaas ---
# Não coloques RIOT_API_KEY aqui: essa chave fica só em backend/.env (nunca no bundle Vite).
# Origem só — sem /api no fim (o cliente chama ${VITE_API_URL}/api/prepareRiotOAuth).
# Dev local com npm run dev:all:
# VITE_API_URL=http://localhost:8787
# Produção (Railway):
# VITE_API_URL=https://xxx.up.railway.app
VITE_API_URL=
# Alias opcional (mesmo valor que VITE_API_URL)
# VITE_BACKEND_URL=http://localhost:8787
# Só se usares rotas /api na Vercel sem backend dedicado:
# VITE_VERCEL_API_URL=https://teu-projeto.vercel.app

# Cloud Messaging (Web Push)
# VITE_FCM_VAPID_KEY=

# --- Só no servidor: copia isto para backend/.env (ou Railway), não para este ficheiro ---
# FIREBASE_SERVICE_ACCOUNT_JSON=...
# RIOT_API_KEY=... + RIOT_OAUTH_* + RIOT_ACCOUNT_ROUTING + RIOT_PLATFORM_ROUTING
# (hosts riotgames.com são fixos no código do backend; vê backend/.env.example)
# ASAAS_* …
