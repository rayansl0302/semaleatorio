# Copie para .env e preencha (Console Firebase → Configuração do projeto)

# Produção: domínio .gg — LP em / e app em /app (sem barra no final)
# VITE_PUBLIC_SITE_URL=https://semaleatorio.gg

# Obrigatórios para Auth (Google): todos abaixo, copiados juntos do Console (mesmo app Web).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
# Obrigatório para o proxy das Cloud Functions em `npm run dev` (evita CORS no localhost).
VITE_FIREBASE_PROJECT_ID=
#
# Se aparecer functions/not-found com o .env preenchido: o URL no Google ainda não tem a função.
# Faça deploy: npx firebase-tools login && npx firebase-tools deploy --only functions
# (use .firebaserc com o mesmo projectId que VITE_FIREBASE_PROJECT_ID).
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Região das Cloud Functions (igual ao deploy; padrão us-central1)
# VITE_FIREBASE_FUNCTIONS_REGION=us-central1
# Realtime Database — Console → Realtime Database → copiar URL (ex.: https://<projeto>-default-rtdb.firebaseio.com)
VITE_FIREBASE_DATABASE_URL=
# Opcional — Google Analytics no mesmo projeto
VITE_FIREBASE_MEASUREMENT_ID=

# Cloud Messaging (Web Push) — Console Firebase → Cloud Messaging → Web Push certificates
VITE_FCM_VAPID_KEY=

# Riot API — usado só pelas Cloud Functions (NUNCA use prefixo VITE_).
# Coloque na raiz (este arquivo) e/ou em functions/.env — o código carrega os dois.
RIOT_API_KEY=
# Plataforma LoL para League v4 (docs: Platform Routing Values). Brasil = br1
RIOT_PLATFORM_ROUTING=br1
#
# OAuth RSO (login do jogador em auth.riotgames.com) — app aprovada no portal Riot.
# redirect_uri deve ser EXATAMENTE a URL registada (ex.: dev e prod podem ser duas entradas).
# RIOT_OAUTH_REDIRECT_URI=http://localhost:5173/app/riot-callback
RIOT_OAUTH_CLIENT_ID=
RIOT_OAUTH_CLIENT_SECRET=
RIOT_OAUTH_REDIRECT_URI=
#
# Em produção (Google Cloud), defina RIOT_API_KEY e RIOT_OAUTH_* nas variáveis da função
# se o .env não for enviado no deploy.
