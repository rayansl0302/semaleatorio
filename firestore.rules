rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    /** Igual a [u1,u2].sort().join('_') no cliente (threadIdFor). */
    function messageThreadIdFor(u1, u2) {
      return u1 <= u2 ? u1 + '_' + u2 : u2 + '_' + u1;
    }

    // Campos alterados apenas pelo backend (Functions / webhook).
    function touchesServerOnlyUserFields() {
      return request.resource.data.diff(resource.data).changedKeys()
        .hasAny([
          'ratingAvg',
          'ratingCount',
          'semiAleatorio',
          'shadowBanned',
          'reportsCount',
          'premiumUntil',
          'asaasCustomerId',
        ]);
    }

    /** Só pode ficar true se existir `admins/{uid}` (evita esconder perfil sem ser staff). */
    function adminPanelOnlyWriteValid(userId) {
      return !request.resource.data.diff(resource.data).changedKeys().hasAny(['adminPanelOnly'])
        || request.resource.data.adminPanelOnly != true
        || exists(/databases/$(database)/documents/admins/$(userId));
    }

    match /users/{userId} {
      allow read: if true;

      allow create: if isOwner(userId)
        && request.resource.data.uid == userId
        && !request.resource.data.keys().hasAny([
          'premiumUntil',
          'asaasCustomerId',
        ])
        && request.resource.data.adminPanelOnly != true;

      allow update: if isOwner(userId)
        && !touchesServerOnlyUserFields()
        && adminPanelOnlyWriteValid(userId);

      allow delete: if isOwner(userId);
    }

    /** Mapa slug → uid para URLs /u/:slug */
    match /profileSlugIndex/{slug} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly(['uid'])
        && request.resource.data.uid == request.auth.uid;
      allow update: if signedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /posts/{postId} {
      allow read: if true;

      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 200
        && request.resource.data.description is string
        && request.resource.data.description.size() <= 2000
        && request.resource.data.eloMin is string
        && request.resource.data.role is string
        && request.resource.data.queueType in ['duo', 'flex', 'clash']
        && request.resource.data.createdAt == request.time;

      allow update, delete: if signedIn()
        && resource.data.uid == request.auth.uid;
    }

    // Mensagens: leitura só para remetente/destinatário.
    // create: não use createdAt == request.time com serverTimestamp() no cliente (falha e bloqueia escrita).
    match /messages/{msgId} {
      allow read: if signedIn()
        && (resource.data.fromUid == request.auth.uid
            || resource.data.toUid == request.auth.uid);

      allow create: if signedIn()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toUid is string
        && request.resource.data.toUid != request.auth.uid
        && request.resource.data.threadId is string
        && request.resource.data.threadId
          == messageThreadIdFor(
            request.resource.data.fromUid,
            request.resource.data.toUid
          )
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 4000
        && request.resource.data.keys().hasOnly(['threadId', 'fromUid', 'toUid', 'text', 'createdAt']);

      allow update, delete: if false;
    }

    // Leitura só com login. Create detalhado (o app grava avaliações pelo cliente).
    match /ratings/{ratingId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          'fromUid',
          'toUid',
          'communication',
          'skill',
          'toxicity',
          'overall',
          'createdAt',
        ])
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toUid is string
        && request.resource.data.toUid != request.auth.uid
        && ratingId == request.auth.uid + '__' + request.resource.data.toUid
        && request.resource.data.communication is int
        && request.resource.data.communication >= 1
        && request.resource.data.communication <= 5
        && request.resource.data.skill is int
        && request.resource.data.skill >= 1
        && request.resource.data.skill <= 5
        && request.resource.data.toxicity is int
        && request.resource.data.toxicity >= 1
        && request.resource.data.toxicity <= 5
        && request.resource.data.overall is number
        && request.resource.data.overall >= 1
        && request.resource.data.overall <= 5
        && request.resource.data.createdAt == request.time;

      allow update, delete: if false;
    }

    match /reports/{reportId} {
      allow create: if signedIn()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toUid is string
        && request.resource.data.toUid != request.auth.uid
        && request.resource.data.reason is string
        && request.resource.data.reason.size() > 0
        && request.resource.data.reason.size() <= 64
        && request.resource.data.detail is string
        && request.resource.data.detail.size() <= 500
        && request.resource.data.createdAt == request.time;

      allow read, update, delete: if false;
    }

    match /seed_profiles/{id} {
      allow read: if true;
      allow write: if false;
    }

    match /config/{doc} {
      allow read: if true;
      /** UIDs de staff a ocultar em Jogadores/feed (actualizado por admins ao iniciar sessão). */
      allow write: if doc == 'staff_players_hide'
        && isAdmin()
        && request.resource.data.keys().hasOnly(['uids'])
        && request.resource.data.uids is list
        && request.resource.data.uids.size() <= 500;
    }

    /** Registo inicial: só o email master pode criar o próprio documento. */
    match /admins/{uid} {
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.auth.token.email != null
        && request.auth.token.email.lower() == 'rayansl.dev@gmail.com'
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.role == 'global'
        && request.resource.data.keys().hasOnly(['email', 'role', 'createdAt'])
        && request.resource.data.createdAt == request.time;

      allow read: if signedIn()
        && (request.auth.uid == uid || isAdmin());

      allow update, delete: if false;
    }

    match /webhook_events/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    /** Cópia permanente do payload Asaas (histórico além dos ~14 dias do painel Asaas). Só o backend escreve. */
    match /webhook_delivery_logs/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
