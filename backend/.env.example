# Servidor SemAleatório — variáveis sensíveis só aqui (ou no Railway).
# O front-end só conhece VITE_API_URL; não recebe RIOT_API_KEY.

PORT=8787

SWAGGER_ENABLED=1
PUBLIC_API_URL=

FIREBASE_SERVICE_ACCOUNT_JSON=

# Riot: chave de jogo + OAuth (o backend chama auth.riotgames.com e *.api.riotgames.com com X-Riot-Token)
RIOT_API_KEY=
RIOT_ACCOUNT_ROUTING=americas
RIOT_PLATFORM_ROUTING=br1
RIOT_OAUTH_CLIENT_ID=
RIOT_OAUTH_CLIENT_SECRET=
RIOT_OAUTH_REDIRECT_URI=https://teu-dominio.vercel.app/app/riot-callback

ASAAS_API_KEY=
ASAAS_API_BASE=https://api-sandbox.asaas.com/v3
ASAAS_WEBHOOK_TOKEN=
